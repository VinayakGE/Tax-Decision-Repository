{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "decision-schema.json",
  "title": "Decision",
  "description": "Schema for a named, bounded decision in the Jarviz Tax Decision Repository.",
  "type": "object",
  "required": ["id", "title", "description", "question", "inputs", "outputs", "rule_refs", "tree_ref", "status", "version", "assessment_years"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^D-[0-9]{3}$",
      "description": "Unique decision ID. Format: D-XXX"
    },
    "title": {
      "type": "string",
      "description": "Short label for this decision."
    },
    "description": {
      "type": "string",
      "description": "Scope and context of this decision."
    },
    "question": {
      "type": "string",
      "description": "The exact question this decision answers."
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "source"],
        "properties": {
          "field": { "type": "string" },
          "source": { "type": "string" },
          "evidence_ref": { "type": "string", "pattern": "^E-[0-9]{3}$" },
          "required": { "type": "boolean" }
        }
      },
      "description": "Input fields required to evaluate this decision."
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "type"],
        "properties": {
          "field": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" },
          "possible_values": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "description": "What this decision produces."
    },
    "rule_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^R-[0-9]{4}$"
      },
      "description": "Ordered list of Rule IDs consulted."
    },
    "tree_ref": {
      "type": "string",
      "description": "Path to the corresponding decision tree YAML file."
    },
    "validation_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^V-[0-9]{3}$"
      },
      "description": "Validations run after this decision."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated"],
      "description": "Lifecycle status."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "assessment_years": {
      "type": "array",
      "items": { "type": "string", "pattern": "^AY[0-9]{4}-[0-9]{2}$" },
      "minItems": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
