{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jarviz.in/schemas/replay-schema.json",
  "title": "Jarviz Decision Replay and Execution Log Schema",
  "description": "Schema for combined DEL + Replay records stored in replays/",
  "type": "object",
  "required": [
    "execution_id", "assessment_year", "pipeline_version", "rule_set_version",
    "started_at", "finished_at", "total_duration_ms", "status",
    "evidence_summary", "stage_log", "rules_invoked", "error_log",
    "operational_metrics", "pattern_matching", "completeness_check",
    "intake_questions", "decisions", "tax_computation", "validations_run",
    "validation_summary", "explanation_generated", "final_recommendation",
    "post_filing_outcome", "corrections"
  ],
  "additionalProperties": false,
  "properties": {
    "execution_id": {
      "type": "string",
      "pattern": "^DEL-[0-9]{4}-[0-9]{7}$",
      "description": "Globally unique execution ID, e.g. DEL-2026-0000001"
    },
    "assessment_year": {
      "type": "string",
      "pattern": "^AY[0-9]{4}-[0-9]{2}$"
    },
    "pipeline_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "rule_set_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "total_duration_ms": { "type": "integer", "minimum": 0 },
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "failed", "partial"]
    },
    "case_ref": {
      "type": ["string", "null"],
      "description": "Reference to the case in the case library, if this replay was promoted to a case"
    },

    "evidence_summary": {
      "type": "object",
      "required": ["documents_uploaded", "documents_parsed", "documents_failed", "evidence_refs_loaded", "total_fields_extracted"],
      "properties": {
        "documents_uploaded": { "type": "integer", "minimum": 0 },
        "documents_parsed": { "type": "integer", "minimum": 0 },
        "documents_failed": { "type": "integer", "minimum": 0 },
        "evidence_refs_loaded": {
          "type": "array",
          "items": { "type": "string", "pattern": "^E-[0-9]{3}$" }
        },
        "total_fields_extracted": { "type": "integer", "minimum": 0 }
      }
    },

    "evidence_loaded": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_ref", "source", "loaded", "fields_extracted", "parse_warnings"],
        "properties": {
          "evidence_ref": { "type": "string", "pattern": "^E-[0-9]{3}$" },
          "source": { "type": "string" },
          "loaded": { "type": "boolean" },
          "fields_extracted": { "type": "integer", "minimum": 0 },
          "parse_warnings": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "stage_log": {
      "type": "array",
      "minItems": 1,
      "maxItems": 14,
      "items": {
        "type": "object",
        "required": ["stage", "name", "started_at", "finished_at", "duration_ms", "status", "input_summary", "output_summary", "warnings"],
        "properties": {
          "stage": { "type": "integer", "minimum": 1, "maximum": 14 },
          "name": { "type": "string" },
          "started_at": { "type": "string", "format": "date-time" },
          "finished_at": { "type": "string", "format": "date-time" },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "status": { "type": "string", "enum": ["success", "failed", "skipped", "halted"] },
          "input_summary": { "type": "object" },
          "output_summary": { "type": "object" },
          "warnings": { "type": "array", "items": { "type": "string" } },
          "error": { "type": ["string", "null"] }
        }
      }
    },

    "rules_invoked": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "version", "evaluated", "result"],
        "properties": {
          "rule_id": { "type": "string", "pattern": "^R-[0-9]{4}$" },
          "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "evaluated": { "type": "boolean" },
          "result": { "type": ["boolean", "null"] },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "skip_reason": { "type": ["string", "null"] }
        }
      }
    },

    "error_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "error_type", "message", "timestamp"],
        "properties": {
          "stage": { "type": "integer", "minimum": 1, "maximum": 14 },
          "error_type": { "type": "string" },
          "message": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "fatal": { "type": "boolean" }
        }
      }
    },

    "operational_metrics": {
      "type": "object",
      "required": ["stages_completed", "stages_failed", "total_rules_evaluated", "total_rules_skipped", "questions_asked", "user_wait_time_ms", "system_processing_time_ms"],
      "properties": {
        "stages_completed": { "type": "integer", "minimum": 0 },
        "stages_failed": { "type": "integer", "minimum": 0 },
        "total_rules_evaluated": { "type": "integer", "minimum": 0 },
        "total_rules_skipped": { "type": "integer", "minimum": 0 },
        "questions_asked": { "type": "integer", "minimum": 0 },
        "user_wait_time_ms": { "type": "integer", "minimum": 0 },
        "system_processing_time_ms": { "type": "integer", "minimum": 0 },
        "ai_call_time_ms": { "type": "integer", "minimum": 0 }
      }
    },

    "pattern_matching": {
      "type": "object",
      "required": ["suggested_pattern", "confirmed_pattern", "pattern_confidence", "escalated", "confirmation_questions_asked"],
      "properties": {
        "suggested_pattern": { "type": "string", "pattern": "^PAT-[0-9]{3}$" },
        "confirmed_pattern": { "type": "string", "pattern": "^PAT-[0-9]{3}$" },
        "pattern_confidence": { "type": "number", "minimum": 0, "maximum": 100 },
        "escalated": { "type": "boolean" },
        "confirmation_questions_asked": { "type": "integer", "minimum": 0 }
      }
    },

    "completeness_check": {
      "type": "object",
      "required": ["evidence_completeness_score", "confidence_band", "halted"],
      "properties": {
        "evidence_completeness_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "confidence_band": { "type": "string", "enum": ["A", "B", "C", "D", "E"] },
        "fields_missing": { "type": "array", "items": { "type": "string" } },
        "fields_user_declared": { "type": "array", "items": { "type": "string" } },
        "halted": { "type": "boolean" }
      }
    },

    "conflicts_found": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["conflict_type", "field", "sources", "resolution"],
        "properties": {
          "conflict_type": { "type": "string", "enum": ["amount_mismatch", "presence_mismatch", "classification_mismatch", "missing_source"] },
          "field": { "type": "string" },
          "sources": { "type": "array", "items": { "type": "string" } },
          "resolution": { "type": "string" }
        }
      }
    },

    "intake_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question_id", "question", "user_answer", "field_populated", "answer_source"],
        "properties": {
          "question_id": { "type": "string" },
          "question": { "type": "string" },
          "user_answer": { "type": ["string", "number", "boolean"] },
          "field_populated": { "type": "string" },
          "answer_source": { "type": "string", "enum": ["user_typed", "user_selected", "inferred_from_evidence"] }
        }
      }
    },

    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision_ref", "engine", "outcome", "rules_evaluated"],
        "properties": {
          "decision_ref": { "type": "string", "pattern": "^D-[0-9]{3}$" },
          "engine": { "type": "string" },
          "outcome": { "type": "string" },
          "rules_evaluated": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["rule_id", "result"],
              "properties": {
                "rule_id": { "type": "string", "pattern": "^R-[0-9]{4}$" },
                "result": { "type": "boolean" },
                "outcome_text": { "type": "string" }
              }
            }
          },
          "rules_skipped": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["rule_id", "reason"],
              "properties": {
                "rule_id": { "type": "string", "pattern": "^R-[0-9]{4}$" },
                "reason": { "type": "string" }
              }
            }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },

    "tax_computation": {
      "type": "object",
      "required": ["regime", "gross_total_income", "taxable_income", "total_tax_liability", "refund", "tax_due"],
      "properties": {
        "regime": { "type": "string", "enum": ["new", "old"] },
        "gross_total_income": { "type": "integer", "minimum": 0 },
        "deductions_allowed": { "type": "integer", "minimum": 0 },
        "taxable_income": { "type": "integer", "minimum": 0 },
        "slab_tax": { "type": "integer", "minimum": 0 },
        "special_tax": { "type": "integer", "minimum": 0 },
        "gross_tax": { "type": "integer", "minimum": 0 },
        "rebate_87A": { "type": "integer", "minimum": 0 },
        "tax_after_rebate": { "type": "integer", "minimum": 0 },
        "surcharge": { "type": "integer", "minimum": 0 },
        "cess": { "type": "integer", "minimum": 0 },
        "total_tax_liability": { "type": "integer", "minimum": 0 },
        "tds_credit": { "type": "integer", "minimum": 0 },
        "advance_tax_paid": { "type": "integer", "minimum": 0 },
        "total_taxes_paid": { "type": "integer", "minimum": 0 },
        "refund": { "type": "integer", "minimum": 0 },
        "tax_due": { "type": "integer", "minimum": 0 }
      }
    },

    "validations_run": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["validation_ref", "result", "severity"],
        "properties": {
          "validation_ref": { "type": "string", "pattern": "^V-[0-9]{3}$" },
          "result": { "type": "string", "enum": ["pass", "fail"] },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "blocking": { "type": "boolean" },
          "details": { "type": ["string", "null"] },
          "remediation": { "type": ["string", "null"] }
        }
      }
    },

    "validation_summary": {
      "type": "object",
      "required": ["total_run", "passed", "failed", "critical_failures", "blocked"],
      "properties": {
        "total_run": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "critical_failures": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "boolean" }
      }
    },

    "explanation_generated": { "type": "boolean" },
    "explanation_sections": {
      "type": "array",
      "items": { "type": "string" }
    },

    "final_recommendation": {
      "type": "object",
      "required": ["itr_form", "regime", "refund_or_due", "amount", "blocked_by_validation"],
      "properties": {
        "itr_form": { "type": "string", "enum": ["ITR-1", "ITR-2", "ITR-3", "ITR-4"] },
        "regime": { "type": "string", "enum": ["new", "old"] },
        "refund_or_due": { "type": "string", "enum": ["refund", "due", "nil"] },
        "amount": { "type": "integer", "minimum": 0 },
        "blocked_by_validation": { "type": "boolean" },
        "blocking_validation": { "type": ["string", "null"] }
      }
    },

    "post_filing_outcome": {
      "type": "object",
      "required": ["recorded_at", "actual_form_filed", "actual_regime_filed", "jarviz_accepted", "override_reason", "notice_received", "outcome_category", "notes"],
      "properties": {
        "recorded_at": { "type": ["string", "null"], "format": "date-time" },
        "actual_form_filed": { "type": ["string", "null"], "enum": ["ITR-1", "ITR-2", "ITR-3", "ITR-4", null] },
        "actual_regime_filed": { "type": ["string", "null"], "enum": ["new", "old", null] },
        "jarviz_accepted": { "type": ["boolean", "null"] },
        "override_reason": { "type": ["string", "null"], "enum": ["jarviz_error", "human_preference", "data_not_provided", "ca_disagreed", "ambiguous", null] },
        "notice_received": { "type": ["boolean", "null"] },
        "outcome_category": { "type": ["string", "null"], "enum": ["accepted_no_notice", "accepted_notice", "overridden_jarviz_error", "overridden_human_preference", "pending", null] },
        "notes": { "type": ["string", "null"] }
      }
    },

    "corrections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["corrected_at", "corrected_by", "field", "old_value", "new_value", "reason"],
        "properties": {
          "corrected_at": { "type": "string", "format": "date-time" },
          "corrected_by": { "type": "string" },
          "field": { "type": "string" },
          "old_value": {},
          "new_value": {},
          "reason": { "type": "string" }
        }
      }
    }
  }
}
