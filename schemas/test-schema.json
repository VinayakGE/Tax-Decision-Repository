{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "test-schema.json",
  "title": "Test",
  "description": "Schema for a rule or decision test case.",
  "type": "object",
  "required": ["id", "title", "target_type", "target_ref", "input", "expected_output", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^T-[0-9]{4}$",
      "description": "Unique test ID. Format: T-XXXX"
    },
    "title": {
      "type": "string",
      "description": "Short scenario description."
    },
    "target_type": {
      "type": "string",
      "enum": ["rule", "decision", "validation"],
      "description": "What this test verifies."
    },
    "target_ref": {
      "type": "string",
      "description": "ID of the rule, decision, or validation being tested."
    },
    "input": {
      "type": "object",
      "description": "Key-value pairs of input fields for this test.",
      "additionalProperties": true
    },
    "expected_output": {
      "type": "object",
      "description": "Expected result values.",
      "additionalProperties": true
    },
    "actual_output": {
      "type": ["object", "null"],
      "description": "Actual result from last test run. Null if not yet run.",
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "pending", "skipped"],
      "description": "Last known test result."
    },
    "last_run": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp of last run."
    },
    "assessment_year": {
      "type": "string",
      "pattern": "^AY[0-9]{4}-[0-9]{2}$"
    },
    "notes": {
      "type": "string"
    }
  }
}
