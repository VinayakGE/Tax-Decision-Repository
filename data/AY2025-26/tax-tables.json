      "applicable_to": "Listed equity shares and equity-oriented MFs held < 12 months",
      "effective_from": "2024-07-23",
      "previous_rate": 0.15,
      "note": "Rate changed from 15% to 20% by Finance Act 2024 effective 23 July 2024. Transactions before this date taxed at 15%."
    },
    "stcg_111A_pre_july23": {
      "rate": 0.15,
      "section": "111A",
      "applicable_to": "Listed equity shares and equity-oriented MFs — transactions on or before 22 July 2024",
      "effective_until": "2024-07-22"
    },
    "ltcg_112A": {
      "rate": 0.125,
      "section": "112A",
      "exemption": 125000,
      "applicable_to": "Listed equity shares and equity-oriented MFs held ≥ 12 months",
      "effective_from": "2024-07-23",
      "previous_rate": 0.10,
      "previous_exemption": 100000,
      "note": "Rate changed from 10% to 12.5% and exemption from ₹1L to ₹1.25L by Finance Act 2024 effective 23 July 2024"
    },
    "ltcg_112A_pre_july23": {
      "rate": 0.10,
      "section": "112A",
      "exemption": 100000,
      "applicable_to": "Listed equity shares and equity-oriented MFs — transactions on or before 22 July 2024",
      "effective_until": "2024-07-22"
    },
    "ltcg_112": {
      "rate": 0.125,
      "section": "112",
      "applicable_to": "Non-equity assets (property, debt MFs, gold) held ≥ 24 months",
      "effective_from": "2024-07-23",
      "indexation_available": false,
      "note": "Indexation removed by Finance Act 2024. For property acquired before 23 Jul 2024, taxpayer may opt for 20% with indexation (old Section 112 rate) if that results in lower tax"
    },
    "ltcg_112_pre_july23": {
      "rate": 0.20,
      "section": "112",
      "applicable_to": "Non-equity assets — transactions on or before 22 July 2024",
