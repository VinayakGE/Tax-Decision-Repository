      "effective_until": "2024-07-22"
    },
    "stcg_other": {
      "rate": "slab",
      "section": null,
      "applicable_to": "Non-equity assets held < 24 months — taxed at normal slab rate"
    },
    "lottery_115BB": {
      "rate": 0.30,
      "section": "115BB",
      "applicable_to": "Lottery, crossword puzzle, game show, horse race winnings",
      "note": "No deduction allowed against lottery income. No basic exemption offset."
    },
    "crypto_115BBH": {
      "rate": 0.30,
      "section": "115BBH",
      "applicable_to": "Virtual Digital Assets (cryptocurrency, NFTs)",
      "note": "1% TDS on transfer u/s 194S. No deduction except cost of acquisition. Losses cannot be set off.",
      "effective_from": "2022-04-01"
    }
