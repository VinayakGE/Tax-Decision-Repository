  "surcharge": {
    "applicable_above": 5000000,
    "brackets": [
      { "income_above": 5000000,  "income_upto": 10000000, "rate": 0.10 },
      { "income_above": 10000000, "income_upto": 20000000, "rate": 0.15 },
      { "income_above": 20000000, "income_upto": 50000000, "rate": 0.25 },
      { "income_above": 50000000, "income_upto": null,     "rate": 0.37 }
    ],
    "new_regime_cap": {
      "max_rate": 0.25,
      "note": "Surcharge capped at 25% under New Regime (Finance Act 2023). Old bracket of 37% applies only under Old Regime."
    },
    "ltcg_112A_surcharge_cap": {
      "max_rate": 0.15,
      "section": "112A",
      "note": "Surcharge on LTCG u/s 112A capped at 15% regardless of income"
    },
    "marginal_relief": {
      "applicable": true,
      "note": "Marginal relief applicable where surcharge + tax exceeds income above the threshold. Compute and apply."
    }
  },

  "cess": {
    "rate": 0.04,
    "name": "Health and Education Cess",
    "applicable_on": "tax_after_rebate + surcharge",
    "authority": "Finance Act 2018 — 3% Education Cess replaced by 4% H&E Cess"
  },

  "alternate_minimum_tax": {
    "rate": 0.185,
    "applicable_to": ["LLP", "non-company-persons-claiming-certain-deductions"],
    "note": "AMT u/s 115JC applies when regular tax < 18.5% of adjusted total income. Not applicable to individuals unless claiming deductions under 10AA, 35AD, 80H-80RRB.",
    "section": "115JC"
  },

  "advance_tax_schedule": {
    "applicable_if_liability_exceeds": 10000,
    "installments": [
      { "due_by": "June 15",    "cumulative_pct": 15 },
      { "due_by": "September 15", "cumulative_pct": 45 },
      { "due_by": "December 15",  "cumulative_pct": 75 },
      { "due_by": "March 15",     "cumulative_pct": 100 }
    ],
    "note": "Individuals with salary income only — TDS by employer covers advance tax. Business/professional income requires self-payment."
  },

  "interest_sections": {
    "234A": {
      "rate_per_month": 0.01,
      "on": "tax_due",
      "trigger": "Return filed after due date",
      "note": "Simple interest from due date to actual filing date"
    },
    "234B": {
      "rate_per_month": 0.01,
      "on": "tax_due_minus_advance_tax",
      "trigger": "Advance tax paid < 90% of tax liability",
      "note": "From April 1 of AY to date of assessment/payment"
    },
    "234C": {
      "rate_per_month": 0.01,
      "on": "shortfall_in_installment",
      "trigger": "Advance tax installment not paid on time",
      "note": "3 months interest per deferred installment; 1 month for March installment"
    }
  },

